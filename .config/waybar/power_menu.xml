                    </object>
                </child>
            </object>
        </child>
        <child>
            <object class="GtkMenuItem" id="logout">
                <child>
                    <object class="GtkBox">
                        <property name="spacing">8</property>
                        <child>
                            <object class="GtkImage">
                                <property name="icon-name">system-log-out-symbolic</property>
                            </object>
                        </child>
